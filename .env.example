# 与主应用共用同一 Redis 时，URL / LLM_ARQ_QUEUE_NAME 需一致
REDIS_URL=redis://127.0.0.1:6379/0
# 与 redis.conf requirepass 一致；含特殊字符亦可。若已写在 URL 中（redis://:pwd@host/0）可省略
# REDIS_PASSWORD=
# LLM_REDIS_PASSWORD=
# arq 任务队列（Redis ZSET 键名），默认 llm_task
# LLM_ARQ_QUEUE_NAME=llm_task
# 单次大模型 HTTP 超时（秒），默认 300 = 5 分钟，与主站 LLM_HTTP_TIMEOUT_SECONDS 对齐
# LLM_HTTP_TIMEOUT_SECONDS=300
# 同时进行的 OpenAI 兼容 HTTP 请求上限
LLM_WORKER_MAX_JOBS=4
LOG_LEVEL=INFO
# 可选：部分厂商需在请求头追加，如 Azure OpenAI
# LLM_EXTRA_HEADERS_JSON={"api-version":"2024-02-15-preview"}
